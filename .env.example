# ============================================
# SEO 자동 블로그 환경설정
# 이 파일을 복사: cp .env.example .env
# ============================================

# ── 필수 설정 ──────────────────────────────

# OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
# 신규 가입 시 $5 무료 크레딧 제공
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# 데이터베이스 (SQLite - 개발용)
DATABASE_URL="file:./dev.db"

# 프로덕션 PostgreSQL 사용 시:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"


# ── 사이트 기본 설정 ──────────────────────

# 사이트 URL (배포 후 실제 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# 사이트 이름
NEXT_PUBLIC_SITE_NAME=Smart Info Blog

# 사이트 설명
NEXT_PUBLIC_SITE_DESCRIPTION=건강, IT, 경제, 생활정보 등 유용한 정보 블로그


# ── Google AdSense ─────────────────────────
# https://adsense.google.com 에서 발급
# 형식: ca-pub-XXXXXXXXXXXXXXXXX

NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX

# 광고 슬롯 ID (AdSense에서 광고 단위 생성 후 입력)
NEXT_PUBLIC_ADSENSE_SLOT_TOP=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_MIDDLE=0987654321
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=1122334455
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=5544332211


# ── Google Analytics 4 ─────────────────────
# https://analytics.google.com 에서 발급
# 형식: G-XXXXXXXXXX

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ── Google Search Console ──────────────────
# https://search.google.com/search-console 에서 사이트 추가 후 인증 코드 입력

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxx


# ── 자동화 설정 ───────────────────────────

# 하루 최대 발행 글 수 (권장: 1~5)
DAILY_POST_LIMIT=3

# 발행 가능 시작 시간 (24시간제)
PUBLISH_START_HOUR=9

# 발행 가능 종료 시간
PUBLISH_END_HOUR=21


# ── 배포 설정 (Vercel) ────────────────────
# vercel.json 또는 환경변수 대시보드에서 설정
# NODE_ENV=production 은 Vercel이 자동 설정
