// Prisma Schema - 다이어트·건강 백과 (PostgreSQL / Neon)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// Author (E-E-A-T 전문가 저자)
// ─────────────────────────────────────────────────────────
model Author {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  title       String   // 직함: "생활스포츠지도사 1급"
  bio         String   @db.Text
  expertise   String[] // 카테고리 ID 배열: ["diet","exercise","nutrition"]
  avatar      String?  // 프로필 이미지 URL
  email       String?
  credentials String[] // 자격증: ["생활스포츠지도사 1급", "스포츠영양사"]
  socialLinks Json?    // { twitter, instagram, youtube }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

// ─────────────────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────────────────
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  accent      String    @default("coral") // coral | sage | rose
  order       Int       @default(99)
  keywords    Keyword[]
  posts       Post[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────
// Topic (에디토리얼 캘린더 주제)
// ─────────────────────────────────────────────────────────
model Topic {
  id           String    @id @default(cuid())
  title        String
  categoryId   String
  keyword      String
  searchVolume Int       @default(0)
  cpcKrw       Int?
  difficulty   Int       @default(50)
  priority     Int       @default(50)
  plannedDate  DateTime?
  status       String    @default("PENDING") // PENDING | DRAFTED | PUBLISHED
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())

  @@index([categoryId, priority])
}

// ─────────────────────────────────────────────────────────
// Post
// status: DRAFT | QUALITY_REJECTED | REVIEW_REQUIRED | APPROVED | PUBLISHED | ARCHIVED
// ─────────────────────────────────────────────────────────
model Post {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  excerpt         String
  content         String
  keywords        String    // JSON 배열 문자열
  tags            String[]  // 태그 배열
  metaTitle       String?
  metaDescription String?
  status          String    @default("DRAFT")
  publishedAt     DateTime?
  scheduledAt     DateTime?
  lastUpdatedAt   DateTime?
  viewCount       Int       @default(0)
  readTime        Int?
  thumbnail       String?   // 대표 이미지 URL
  coverImage      String?   // OG 이미지 URL (1200×630)

  // Quality gate
  qualityScore    Int?      // 0~100
  rejectReasons   String[]  // 품질 거절 사유 목록
  sources         Json?     // [{ title, url, publisher }]
  internalLinks   Json?     // [{ slug, title }]
  factReport      Json?     // 팩트체크 결과

  // Review workflow
  reviewedBy      String?   // 감수자 이름
  reviewedAt      DateTime?
  reviewNotes     String?   @db.Text

  // Author (E-E-A-T)
  authorId        String?
  author          Author?   @relation(fields: [authorId], references: [id])

  // YouTube
  shortsGenerated   Boolean   @default(false)
  shortsVideoId     String?
  longformGenerated Boolean   @default(false)
  longformVideoId   String?

  // Coupang
  coupangProduct  String?   // JSON: {name, url, image?, price?, ctaText?}

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  keywordId   Int?     @unique
  mainKeyword Keyword? @relation(fields: [keywordId], references: [id])

  relatedPosts PostRelation[] @relation("PostRelations")
  relatedTo    PostRelation[] @relation("RelatedTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([slug])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────
// Keyword
// ─────────────────────────────────────────────────────────
model Keyword {
  id           Int       @id @default(autoincrement())
  keyword      String    @unique
  searchVolume Int?
  competition  Float?
  difficulty   Int?
  used         Boolean   @default(false)
  priority     Int       @default(5)
  categoryId   Int?
  category     Category? @relation(fields: [categoryId], references: [id])
  post         Post?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([used, priority])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────
// PostRelation (연관 글)
// ─────────────────────────────────────────────────────────
model PostRelation {
  id        Int  @id @default(autoincrement())
  postId    Int
  relatedId Int
  post      Post @relation("PostRelations", fields: [postId], references: [id])
  related   Post @relation("RelatedTo", fields: [relatedId], references: [id])

  @@unique([postId, relatedId])
}

// ─────────────────────────────────────────────────────────
// AutomationLog
// ─────────────────────────────────────────────────────────
model AutomationLog {
  id        Int      @id @default(autoincrement())
  type      String   // KEYWORD_COLLECT | CONTENT_GENERATE | POST_PUBLISH | QUALITY_AUDIT | ERROR
  status    String   // SUCCESS | FAILED | PENDING
  message   String
  details   String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

// ─────────────────────────────────────────────────────────
// Visitor
// ─────────────────────────────────────────────────────────
model Visitor {
  id        Int      @id @default(autoincrement())
  date      String   @unique  // YYYY-MM-DD
  count     Int      @default(0)
  unique    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ─────────────────────────────────────────────────────────
// SiteConfig
// ─────────────────────────────────────────────────────────
model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
